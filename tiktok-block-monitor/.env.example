# Copia este archivo a .env y rellena los valores.

# Usuarios de TikTok a vigilar (sin la @), separados por comas.
# Ejemplo: TARGETS=usuario1,usuario2
TARGETS=

# Ejecuta el navegador en modo visible (false) o sin interfaz (true).
# Sugerencia: false reduce la huella de automatización.
HEADLESS=true

# --- Programación (modo watch): solo comprueba dentro de estas franjas ---
# Hora local. 24:00 = medianoche. Separa varias franjas con comas.
CHECK_WINDOWS=08:00-12:00,18:00-24:00

# Hueco ALEATORIO entre comprobaciones, en minutos (rompe el patrón uniforme).
MIN_GAP_MINUTES=60
MAX_GAP_MINUTES=150

# Tope de comprobaciones por día (seguridad anti-baneo).
DAILY_MAX=8

# --- Retardo aleatorio entre cuentas (segundos) ---
ACCOUNT_DELAY_MIN_SECONDS=20
ACCOUNT_DELAY_MAX_SECONDS=60

# --- Backoff si TikTok nos limita (429 / captcha), en horas ---
BACKOFF_HOURS_MIN=6
BACKOFF_HOURS_MAX=12

# Simular comportamiento humano (scroll, ratón, esperas variables): true/false.
HUMANIZE=true

# (Opcional) Webhook para recibir notificaciones de cambios de estado.
# Puede ser un webhook de Discord, Slack o cualquier endpoint que acepte JSON.
NOTIFY_WEBHOOK_URL=

# (Opcional) User-Agent personalizado para el navegador.
USER_AGENT=
